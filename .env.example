# ─────────────────────────────────────────────────────────────────────────────
# AI Cargo Cold Chain — Production Environment Variables
# Copy to .env and fill in real values. Never commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
# REST + Auth (used by supabase-py client)
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_KEY=<service-role-key>

# Direct Postgres connection string (used by LangGraph Postgres checkpointer)
# Find in: Supabase → Project Settings → Database → Connection string (URI)
# Use the "Session mode" pooler URL on port 5432 for Railway compatibility.
SUPABASE_DB_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Set exactly one provider. Priority order if multiple are set: groq > openai > anthropic > ollama
GROQ_API_KEY=<groq-api-key>

# Free embeddings via Google Gemini API. Get key at: https://aistudio.google.com (no billing required)
GEMINI_API_KEY=<gemini-api-key>

# ── LangSmith Observability ───────────────────────────────────────────────────
# Get your API key at: https://smith.langchain.com → Settings → API Keys
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=<langsmith-api-key>
LANGCHAIN_PROJECT=ai-cargo-cold-chain

# ── Notifications ─────────────────────────────────────────────────────────────
NOTIFICATION_MODE=production
EMAIL_PROVIDER=gmail_smtp
GMAIL_EMAIL=<your-gmail>
GMAIL_APP_PASSWORD=<gmail-app-password>
GMAIL_FROM_NAME=AI Cargo Cold Chain Alerts
# Remove this in production to send to real stakeholder emails:
# EMAIL_RECIPIENT_OVERRIDE=<your-test-inbox>

# ── CORS ──────────────────────────────────────────────────────────────────────
# Set to your Vercel frontend URL so the backend accepts requests from it
FRONTEND_URL=https://<your-app>.vercel.app

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ─────────────────────────────────────────────────────────────────────────────
# Frontend (Vercel) — set these in Vercel Dashboard → Project → Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# VITE_API_URL=https://<service-name>-<hash>-uc.a.run.app
